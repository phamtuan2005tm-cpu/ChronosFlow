<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ChronosFlow - Create Account</title>
    <link rel="icon"
        href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>⏳</text></svg>">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
</head>

<body>

    <div class="login-wrapper">
        <div class="login-card">

            <div class="brand-header">
                <h2 class="brand-title">Create Account</h2>
                <p class="brand-slogan">Join ChronosFlow today and control your time</p>
            </div>

            <% if (typeof error !=='undefined' && error) { %>
                <div
                    style="background-color: #fee2e2; color: #dc2626; padding: 12px; border-radius: 8px; margin-bottom: 16px; font-size: 14px; text-align: center; border: 1px solid #fca5a5; font-weight: 500;">
                    ⚠️ <%= error %>
                </div>
                <% } %>

                    <form action="/register" method="POST" id="registerForm">

                        <div class="form-group">
                            <label class="form-label">Email Address</label>
                            <input type="email" class="form-input" name="email" placeholder="name@domain.com" required>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Password</label>
                            <input type="password" class="form-input" name="password"
                                placeholder="At least 6 characters" required>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Confirm Password</label>
                            <input type="password" class="form-input" name="confirmPassword"
                                placeholder="Repeat your password" required>
                        </div>

                        <div class="form-check">
                            <input type="checkbox" id="terms" required>
                            <label for="terms">I agree to the Terms & Conditions</label>
                        </div>

                        <button type="submit" class="btn-submit">Sign Up</button>

                        <div class="form-footer">
                            <span>Already have an account? </span>
                            <a href="/login" class="forgot-link">Sign In</a>
                        </div>

                    </form>
        </div>
    </div>

    <script>
        document.getElementById('registerForm').addEventListener('submit', async function (e) {
            // Chỉ kích hoạt Fetch nếu form không tự gửi được theo cách truyền thống
            console.log("✈️ Form submit event triggered smoothly!");
        });
    </script>

</body>

</html>