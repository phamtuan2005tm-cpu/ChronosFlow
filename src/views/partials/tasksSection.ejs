<div class="task-management-wrapper" style="padding: 20px; font-family: 'Segoe UI', system-ui, sans-serif;">

    <section id="project-hub-zone" style="margin-bottom: 30px;">
        <div class="header-content" style="margin-bottom: 20px;">
            <h1 class="welcome-title">🗂️ Project Workspace</h1>
            <p style="color: #6c757d; font-size: 14px; margin-top: 4px;">Initialize new projects, set milestones, and
                govern your macro targets.</p>
        </div>


        <div class="task-form-card"
            style="background: #fff; padding: 20px; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); margin-bottom: 25px;">
            <h3 class="section-title" style="margin-top: 0; margin-bottom: 15px; color: #1e293b;">🚀 Create New
                Project</h3>

            <div id="project-creation-block" style="display: flex; flex-wrap: wrap; gap: 15px; align-items: flex-end;">
                <div class="form-group"
                    style="flex: 2; min-width: 200px; display: flex; flex-direction: column; gap: 6px;">
                    <label style="font-weight: 600; color: #475569; font-size: 13px;">Project Name</label>
                    <input type="text" id="proj-name" placeholder="e.g., ChronosFlow App, Social Campaign..." required
                        style="padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px;">
                </div>
                <div class="form-group"
                    style="flex: 1; min-width: 130px; display: flex; flex-direction: column; gap: 6px;">
                    <label style="font-weight: 600; color: #475569; font-size: 13px;">Priority</label>
                    <select id="proj-priority"
                        style="padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px; background: #fff;">
                        <option value="Low">Low</option>
                        <option value="Medium" selected>Medium</option>
                        <option value="High">High</option>
                    </select>
                </div>
                <div class="form-group"
                    style="flex: 1; min-width: 160px; display: flex; flex-direction: column; gap: 6px;">
                    <label style="font-weight: 600; color: #475569; font-size: 13px;">Start Date</label>
                    <input type="date" id="proj-startdate" required
                        style="padding: 9px; border: 1px solid #cbd5e1; border-radius: 6px;">
                </div>
                <div class="form-group"
                    style="flex: 1; min-width: 160px; display: flex; flex-direction: column; gap: 6px;">
                    <label style="font-weight: 600; color: #475569; font-size: 13px;">Due Date (Deadline)</label>
                    <input type="date" id="proj-enddate" required
                        style="padding: 9px; border: 1px solid #cbd5e1; border-radius: 6px;">
                </div>

                <button type="button" onclick="submitProjectManually()"
                    style="background: #2563eb; color: #fff; border: none; padding: 11px 20px; border-radius: 6px; font-weight: 600; cursor: pointer;">🚀
                    Launch Project</button>
            </div>
        </div>


        <h3 style="color: #334155; font-size: 16px; margin-bottom: 15px; font-weight: 700;">⏳ Ongoing Projects</h3>

        <div id="project-list-grid"
            style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
        </div>
    </section>

    <section id="active-project-workspace" style="display: none; border-top: 2px dashed #cbd5e1; padding-top: 25px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <div>
                <button onclick="backToProjectHub()"
                    style="background: #64748b; color: #fff; border: none; padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 13px; font-weight: 600; margin-bottom: 8px;">⬅
                    Back to Project Hub</button>
                <h2 id="current-workspace-title" style="margin: 0; color: #1e293b;">📌 Project Workspace: <span
                        id="txt-active-project-name">---</span></h2>
            </div>
            <div id="project-action-buttons-zone"></div>
        </div>

        <section class="task-form-card" style="margin-bottom: 25px; background: #f8fafc; border: 1px solid #e2e8f0;">
            <h3 class="section-title" style="margin-top: 0; color: #334155;">➕ Add Task to Project</h3>
            <form id="kanban-task-form" class="task-inline-form"
                style="display: flex; gap: 15px; align-items: flex-end;">
                <input type="hidden" id="active-project-id">
                <div class="form-group" style="flex: 3; display: flex; flex-direction: column; gap: 4px;">
                    <label style="font-size: 12px; font-weight: 600;">Task Title</label>
                    <input type="text" name="title" id="task-title"
                        placeholder="What needs to be done for this milestone?" required>
                </div>
                <div class="form-group" style="flex: 1; display: flex; flex-direction: column; gap: 4px;">
                    <label style="font-size: 12px; font-weight: 600;">Priority</label>
                    <select id="task-priority" name="priority">
                        <option value="Low">Low</option>
                        <option value="Medium" selected>Medium</option>
                        <option value="High">High</option>
                    </select>
                </div>
                <div class="form-group" style="flex: 1; display: flex; flex-direction: column; gap: 4px;">
                    <label style="font-size: 12px; font-weight: 600;">Due Date</label>
                    <input type="datetime-local" id="task-duedate" required name="dueDate">
                </div>
                <button type="button" onclick="createNewTaskApi()" class="btn-add-task"
                    style="background: #2563eb; color: #fff; border: none; padding: 11px 20px; border-radius: 6px; font-weight: 600; cursor: pointer;">➕
                    Add Task</button>
            </form>
        </section>

        <section class="kanban-board" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;">
            <div class="kanban-column">
                <div class="column-header status-todo">
                    <span>To-Do</span>
                    <span class="task-count" id="count-todo">0</span>
                </div>
                <div class="task-list" id="list-todo" ondragover="allowDrop(event)" ondrop="handleDrop(event, 'To-Do')">
                </div>
            </div>

            <div class="kanban-column">
                <div class="column-header status-progress">
                    <span>In Progress</span>
                    <span class="task-count" id="count-progress">0</span>
                </div>
                <div class="task-list" id="list-progress" ondragover="allowDrop(event)"
                    ondrop="handleDrop(event, 'In Progress')"></div>
            </div>

            <div class="kanban-column">
                <div class="column-header status-done">
                    <span>Done</span>
                    <span class="task-count" id="count-done">0</span>
                </div>
                <div class="task-list" id="list-done" ondragover="allowDrop(event)" ondrop="handleDrop(event, 'Done')">
                </div>
            </div>
        </section>
    </section>
</div>

<div id="task-detail-modal"
    style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(4px); z-index: 9999; justify-content: center; align-items: center;">
    <div
        style="background: #fff; width: 550px; max-height: 85vh; border-radius: 12px; padding: 25px; display: flex; flex-direction: column; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);">
        <div
            style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #e2e8f0; padding-bottom: 12px; margin-bottom: 15px;">
            <h3 id="modal-task-title" style="margin: 0; color: #1e293b; font-size: 18px;">📝 Task Details & Logs</h3>
            <button onclick="closeTaskDetailModal()"
                style="border: none; background: transparent; font-size: 20px; cursor: pointer; color: #94a3b8;">✕</button>
        </div>

        <input type="hidden" id="modal-active-task-id">
        <p style="margin: 4px 0; font-size: 13px; color: #64748b;">Status: <span id="modal-task-status"
                style="font-weight: 700;">---</span> | Deadline: <span id="modal-task-due"
                style="font-weight: 600;">---</span></p>

        <div
            style="margin-top: 15px; background: #f8fafc; padding: 12px; border-radius: 8px; border: 1px solid #e2e8f0;">
            <label style="font-weight: 700; font-size: 13px; color: #334155; display: block; margin-bottom: 6px;">⏱
                Record Current Step Progress (Real-time Log):</label>
            <div style="display: flex; gap: 8px;">
                <input type="text" id="task-log-input" placeholder="What specific step did you accomplish just now?"
                    style="flex: 1; padding: 8px; border: 1px solid #cbd5e1; border-radius: 6px; font-size: 13px;">
                <button onclick="submitTaskLogApi()"
                    style="background: #10b981; color: #fff; border: none; padding: 8px 14px; border-radius: 6px; font-weight: 600; cursor: pointer; font-size: 13px;">✍
                    Log Step</button>
            </div>
        </div>

        <label
            style="font-weight: 700; font-size: 13px; color: #334155; display: block; margin-top: 15px; margin-bottom: 6px;">📜
            Step-by-Step Execution History:</label>
        <div id="task-logs-timeline"
            style="flex: 1; overflow-y: auto; background: #fff; border: 1px solid #e2e8f0; border-radius: 8px; padding: 10px; display: flex; flex-direction: column; gap: 8px; max-height: 220px;">
        </div>
    </div>
</div>

<script src="/js/tasks.js"></script>