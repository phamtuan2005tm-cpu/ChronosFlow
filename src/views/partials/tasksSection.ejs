<div class="header-content">
    <div>
        <h1 class="welcome-title">Task Management</h1>
        <p style="color: #6c757d; font-size: 14px; margin-top: 4px;">Organize, track, and conquer your daily targets.
        </p>
    </div>
</div>

<section class="task-form-card" style="margin-top: 20px; margin-bottom: 20px;">
    <h3 class="section-title">Create New Task</h3>
    <form id="kanban-task-form" class="task-inline-form">
        <div class="form-group flex-3">
            <label>Task Title</label>
            <input type="text" name="title" id="task-title" placeholder="What needs to be done?" required>
        </div>
        <div class="form-group flex-1">
            <label>Priority</label>
            <select id="task-priority" name="priority">
                <option value="Low">Low</option>
                <option value="Medium" selected>Medium</option>
                <option value="High">High</option>
            </select>
        </div>
        <div class="form-group flex-1">
            <label>Due Date</label>
            <input type="datetime-local" id="task-duedate" required name="dueDate">
        </div>
        <button type="submit" class="btn-add-task">➕ Add Task</button>
    </form>
</section>

<section class="kanban-board">

    <div class="kanban-column">
        <div class="column-header status-todo">
            <span>To-Do</span>
            <span class="task-count" id="count-todo">0</span>
        </div>
        <div class="task-list" id="list-todo"></div>
    </div>

    <div class="kanban-column">
        <div class="column-header status-progress">
            <span>In Progress</span>
            <span class="task-count" id="count-progress">0</span>
        </div>
        <div class="task-list" id="list-progress"></div>
    </div>

    <div class="kanban-column">
        <div class="column-header status-done">
            <span>Done</span>
            <span class="task-count" id="count-done">0</span>
        </div>
        <div class="task-list" id="list-done"></div>
    </div>

</section>