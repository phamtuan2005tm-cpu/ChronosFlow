<div class="header-content">
    <div>
        <h1 class="welcome-title">Weekly Timetable</h1>
        <p style="color: #6c757d; font-size: 14px; margin-top: 4px;">Set up your recurring fixed slots for the week.</p>
    </div>
</div>

<section class="schedule-form-card" style="margin-top: 20px; margin-bottom: 20px;">
    <h3 class="section-title">Add Weekly Slot</h3>
    <form action="/schedules" method="POST" class="schedule-inline-form">
        <div class="form-group flex-2">
            <label>Subject / Activity Name</label>
            <input type="text" name="title" placeholder="e.g., Teaching English, Node.js" required>
        </div>
        <div class="form-group flex-1">
            <label>Day of Week</label>
            <select name="dayOfWeek">
                <option value="2">Monday</option>
                <option value="3">Tuesday</option>
                <option value="4">Wednesday</option>
                <option value="5">Thursday</option>
                <option value="6">Friday</option>
                <option value="7">Saturday</option>
                <option value="8">Sunday</option>
            </select>
        </div>
        <div class="form-group flex-1">
            <label>Start Time</label>
            <input type="time" name="startTime" required>
        </div>
        <div class="form-group flex-1">
            <label>End Time</label>
            <input type="time" name="endTime" required>
        </div>
        <button type="submit" class="btn-add-schedule">📅 Add Slot</button>
    </form>
</section>

<section class="timetable-container">
    <table class="timetable-table">
        <thead>
            <tr>
                <th>Time Slot</th>
                <th>Mon</th>
                <th>Tue</th>
                <th>Wed</th>
                <th>Thu</th>
                <th>Fri</th>
                <th>Sat</th>
                <th>Sun</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td class="time-col">08:00 - 11:00</td>
                <td>
                    <div class="slot-box color-blue">Learning Node.js</div>
                </td>
                <td></td>
                <td>
                    <div class="slot-box color-blue">Learning Node.js</div>
                </td>
                <td></td>
                <td></td>
                <td>
                    <div class="slot-box color-navy">Teaching English</div>
                </td>
                <td></td>
            </tr>
            <tr>
                <td class="time-col">14:00 - 17:00</td>
                <td></td>
                <td>
                    <div class="slot-box color-cyan">IELTS Practice</div>
                </td>
                <td></td>
                <td>
                    <div class="slot-box color-cyan">IELTS Practice</div>
                </td>
                <td></td>
                <td></td>
                <td></td>
            </tr>
        </tbody>
    </table>
</section>