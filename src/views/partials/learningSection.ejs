<div class="header-content">
    <div>
        <h1 class="welcome-title">Learning Hub</h1>
        <p style="color: #6c757d; font-size: 14px; margin-top: 4px;">Manage course documents and train with smart AI
            quizzes.</p>
    </div>
</div>

<div class="learning-sub-menu"
    style="display: flex; gap: 8px; margin-top: 20px; border-bottom: 2px solid #e2e8f0; padding-bottom: 8px;">
    <button class="btn-sub-tab active" data-target="panel-subjects" onclick="switchLearningSubTab('panel-subjects')"
        style="padding: 8px 16px; border: none; background: #2563eb; color: white; font-weight: 600; border-radius: 6px; cursor: pointer; font-size: 13px; display: flex; align-items: center; gap: 6px;">
        <i class="fa-solid fa-book"></i> Courses & Materials
    </button>
    <button class="btn-sub-tab" data-target="panel-stopwatch" onclick="switchLearningSubTab('panel-stopwatch')"
        style="padding: 8px 16px; border: none; background: transparent; color: #64748b; font-weight: 600; border-radius: 6px; cursor: pointer; font-size: 13px; display: flex; align-items: center; gap: 6px;">
        <i class="fa-solid fa-stopwatch"></i> Study Timer
    </button>
    <button class="btn-sub-tab" data-target="panel-quiz" onclick="switchLearningSubTab('panel-quiz')"
        style="padding: 8px 16px; border: none; background: transparent; color: #64748b; font-weight: 600; border-radius: 6px; cursor: pointer; font-size: 13px; display: flex; align-items: center; gap: 6px;">
        <i class="fa-solid fa-brain"></i> AI Quiz Generator
    </button>
</div>

<div class="learning-panels-container" style="margin-top: 20px;">

    <div id="panel-subjects" class="learning-panel" style="display: flex; gap: 20px; min-height: 400px;">
        <div
            style="width: 250px; background: #fff; padding: 15px; border-radius: 12px; border: 1px solid #e2e8f0; display: flex; flex-direction: column; gap: 10px; flex-shrink: 0;">
            <div style="display: flex; gap: 6px;">
                <input type="text" id="new-subject-name" placeholder="New course..."
                    style="flex: 1; padding: 6px 10px; border: 1px solid #cbd5e1; border-radius: 6px; font-size: 12px;">
                <button onclick="createNewSubjectApi()"
                    style="padding: 6px 10px; background: #2563eb; color: white; border: none; border-radius: 6px; font-weight: 600; cursor: pointer; font-size: 12px;">+</button>
            </div>
            <div id="subjects-list-group"
                style="display: flex; flex-direction: column; gap: 4px; max-height: 350px; overflow-y: auto;"></div>
        </div>

        <div
            style="flex: 1; background: #fff; padding: 20px; border-radius: 12px; border: 1px solid #e2e8f0; display: flex; flex-direction: column; gap: 15px;">
            <div id="no-subject-selected" style="text-align: center; color: #94a3b8; padding: 40px 0;">
                <i class="fa-solid fa-book-open"
                    style="font-size: 36px; color: #cbd5e1; margin-bottom: 8px; display: block;"></i>
                Select a course from the left menu to view materials.
            </div>
            <div id="subject-detail-content" style="display: none; flex-direction: column; gap: 15px;">
                <h2 id="selected-subject-title" style="margin: 0; font-size: 16px; font-weight: 700; color: #1e293b;">
                </h2>
                <input type="hidden" id="selected-subject-id">
                <div
                    style="display: flex; gap: 8px; background: #f8fafc; padding: 10px; border-radius: 8px; border: 1px solid #e2e8f0;">
                    <input type="text" id="new-doc-title" placeholder="Material name..."
                        style="flex: 1; padding: 6px 10px; border: 1px solid #cbd5e1; border-radius: 6px; font-size: 12px;">
                    <input type="url" id="new-doc-url" placeholder="Drive / Notion URL..."
                        style="flex: 1.5; padding: 6px 10px; border: 1px solid #cbd5e1; border-radius: 6px; font-size: 12px;">
                    <button onclick="createNewDocumentApi()"
                        style="padding: 6px 14px; background: #10b981; color: white; border: none; border-radius: 6px; font-weight: 600; cursor: pointer; font-size: 12px;">Save</button>
                </div>
                <table style="width: 100%; border-collapse: collapse; font-size: 13px; text-align: left;">
                    <thead>
                        <tr style="background: #f8fafc; border-bottom: 1px solid #e2e8f0;">
                            <th style="padding: 8px;">Document Title</th>
                            <th style="padding: 8px; width: 80px;">Action</th>
                        </tr>
                    </thead>
                    <tbody id="documents-table-body"></tbody>
                </table>
            </div>
        </div>
    </div>

    <div id="panel-stopwatch" class="learning-panel"
        style="display: none; background: #fff; padding: 30px; border-radius: 12px; border: 1px solid #e2e8f0; flex-direction: column; align-items: center; gap: 20px; max-width: 450px; margin: 0 auto;">
        <h3 style="margin: 0; font-size: 14px; font-weight: 700; color: #475569; text-transform: uppercase;">Deep Work
            Stopwatch</h3>
        <div id="stopwatch-display"
            style="font-size: 54px; font-weight: 700; color: #1e293b; font-family: monospace; letter-spacing: 2px; padding: 10px 40px; background: #f8fafc; border-radius: 10px; border: 1px solid #e2e8f0;">
            00:00:00</div>
        <div style="display: flex; gap: 10px; width: 100%;">
            <button id="btn-sw-start" onclick="startStopwatch()"
                style="flex: 1; padding: 10px; background: #2563eb; color: white; border: none; border-radius: 8px; font-weight: 600; cursor: pointer;">▶
                Start Session</button>
            <button id="btn-sw-stop" onclick="stopStopwatch()"
                style="flex: 1; padding: 10px; background: #ef4444; color: white; border: none; border-radius: 8px; font-weight: 600; cursor: pointer;"
                disabled>⏸ Pause</button>
            <button id="btn-sw-reset" onclick="resetStopwatch()"
                style="padding: 10px 15px; background: #64748b; color: white; border: none; border-radius: 8px; cursor: pointer;">🔄</button>
        </div>
    </div>

    <div id="panel-quiz" class="learning-panel"
        style="display: none; background: #fff; padding: 25px; border-radius: 12px; border: 1px solid #e2e8f0; min-height: 400px;">
        <h3 style="margin: 0 0 10px 0; font-size: 16px; font-weight: 700; color: #1e293b;"><i class="fa-solid fa-robot"
                style="color: #2563eb;"></i> AI Quiz Generator</h3>
        <div
            style="background: #eff6ff; border: 1px solid #bfdbfe; padding: 15px; border-radius: 8px; font-size: 13px; color: #1e40af; line-height: 1.5;">
            🚀 <strong>Welcome Tuấn! The AI Exam Preparation environment is ready.</strong><br>
            In the upcoming step, we will extract raw data from the URLs you saved in Tab 1, pipe it to the AI, and
            generate direct interactive multi-choice quizzes for you right here!
        </div>
    </div>

</div>

<script src="/js/learning.js"></script>