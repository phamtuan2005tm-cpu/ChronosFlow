<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ChronosFlow</title>
    <link rel="icon"
        href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>⏳</text></svg>">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght=300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="/css/homePageStyles.css">

    <style>
        /* Hiệu ứng chuyển động tịnh tiến êm ái cho cả 2 vùng */
        .sidebar {
            transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1), padding 0.3s ease !important;
            overflow-x: hidden !important;
        }

        .main-content {
            transition: padding-left 0.3s cubic-bezier(0.4, 0, 0.2, 1), margin-left 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
        }

        /* 🔴 1. XỬ LÝ KHI SIDEBAR CO LẠI (COLLAPSED) */
        .sidebar.collapsed {
            width: 75px !important;
            padding-left: 8px !important;
            padding-right: 8px !important;
        }

        /* Ép vùng nội dung chính tràn sang lấp khoảng trống trắng */
        .sidebar.collapsed~.main-content,
        .sidebar.collapsed+.main-content,
        body:has(.sidebar.collapsed) .main-content {
            margin-left: 75px !important;
            padding-left: 20px !important;
        }

        /* Ẩn chữ Menu, ẩn logo dài bằng ảnh */
        .sidebar.collapsed .menu-text,
        .sidebar.collapsed .brand-logo img,
        .sidebar.collapsed .btn-logout span>span {
            display: none !important;
        }

        /* Thay logo dài bằng icon đồng hồ cát nhỏ gọn nằm ngay tâm */
        .sidebar.collapsed .brand-logo {
            display: flex !important;
            justify-content: center !important;
            align-items: center !important;
            width: 100% !important;
            margin: 0 0 10px 0 !important;
            min-height: 40px !important;
        }

        .sidebar.collapsed .brand-logo::before {
            content: "⏳";
            font-size: 24px;
            display: block;
        }

        /* Sắp xếp nút ba gạch nằm dọc ngay dưới icon đồng hồ cát */
        .sidebar.collapsed .sidebar-header-area {
            flex-direction: column-reverse !important;
            gap: 12px !important;
            justify-content: center !important;
            width: 100% !important;
        }

        .sidebar.collapsed .sidebar-header-area button {
            width: 100% !important;
            justify-content: center !important;
            padding: 5px 0 !important;
            display: flex !important;
        }

        /* 🔴 2. BẢO VỆ ICON: ÉP CÁC ICON MENU VÀO TRUNG TÂM HÀNG DỌC */
        .sidebar.collapsed .nav-menu {
            padding: 0 !important;
            margin: 0 !important;
            display: flex !important;
            flex-direction: column !important;
            align-items: center !important;
        }

        .sidebar.collapsed .nav-menu .nav-item {
            width: 100% !important;
            display: flex !important;
            justify-content: center !important;
        }

        /* Khống chế thẻ 'a' thành một khối hộp vuông cân đối để giữ icon */
        .sidebar.collapsed .nav-menu .nav-item a {
            display: flex !important;
            justify-content: center !important;
            align-items: center !important;
            width: 50px !important;
            height: 45px !important;
            padding: 0 !important;
            margin: 4px 0 !important;
            border-radius: 8px !important;
        }

        /* Ép thẻ 'i' hiển thị độc lập, to rõ ràng */
        .sidebar.collapsed .nav-menu .nav-item a i {
            margin: 0 !important;
            font-size: 20px !important;
            display: inline-block !important;
            visibility: visible !important;
            opacity: 1 !important;
        }

        /* 🔴 3. THU GỌN NÚT SIGN OUT DƯỚI ĐÁY */
        .sidebar.collapsed .btn-logout {
            padding: 12px 0 !important;
            justify-content: center !important;
            display: flex !important;
            width: 100% !important;
        }

        .sidebar.collapsed .btn-logout span {
            margin: 0 !important;
            display: flex !important;
            justify-content: center !important;
            width: 100% !important;
        }

        .sidebar.collapsed .btn-logout i {
            margin: 0 !important;
            font-size: 20px !important;
            display: inline-block !important;
        }
    </style>
</head>

<body>

    <aside class="sidebar" id="main-sidebar">
        <div>
            <div style="display: flex; flex-direction: column; align-items: center; justify-content: space-between; margin-bottom: 20px;"
                class="sidebar-header-area">
                <div class="brand-logo" style="margin: 0;">
                    <img src="/images/Dark-Logo.png" alt="ChronosFlow Logo">
                </div>
            </div>
            <button class="nav-item" onclick="toggleSidebar()"
                style="background: transparent; border: none; color: #94a3b8; cursor: pointer; font-size: 18px; padding: 5px; display: flex; align-items: center;">
                <a href="#"><i class="fa-solid fa-bars" id="sidebar-toggle-icon"></i><span
                        class="menu-text">Menu</span></a>
            </button>
            <ul class="nav-menu">
                <li class="nav-item active" data-tab="dashboard">
                    <a href="#"><i class="fa-solid fa-house"></i><span class="menu-text">Dashboard</span></a>
                </li>
                <li class="nav-item" data-tab="schedules">
                    <a href="#"><i class="fa-solid fa-calendar"></i><span class="menu-text">Schedules</span></a>
                </li>
                <li class="nav-item" data-tab="tasks">
                    <a href="#"><i class="fa-solid fa-list-check"></i><span class="menu-text">Tasks</span></a>
                </li>
                <li class="nav-item" data-tab="learning">
                    <a href="#"><i class="fa-solid fa-book"></i><span class="menu-text">Learning</span></a>
                </li>
                <li class="nav-item" data-tab="finance">
                    <a href="#"><i class="fa-solid fa-money-bill-wave"></i><span class="menu-text">Finance</span></a>
                </li>
                <li class="nav-item" data-tab="settings">
                    <a href="#"><i class="fa-solid fa-gear"></i><span class="menu-text">Settings</span></a>
                </li>
            </ul>
        </div>

        <a href="/login" class="btn-logout">
            <span><i class="fa-solid fa-arrow-right-from-bracket"></i><span>Sign Out</span></span>
        </a>
    </aside>

    <main class="main-content">
        <div id="dashboard" class="tab-content active">
            <%- include('partials/dashboardSection') %>
        </div>

        <div id="schedules" class="tab-content">
            <%- include('partials/scheduleSection') %>
        </div>

        <div id="tasks" class="tab-content">
            <%- include('partials/tasksSection') %>
        </div>

        <div id="learning" class="tab-content">
            <%- include('partials/learningSection') %>
        </div>

        <div id="finance" class="tab-content">
            <%- include('partials/financeSection') %>
        </div>

        <div id="settings" class="tab-content">
            <div class="header-content">
                <h1 class="welcome-title">Settings</h1>
            </div>
            <div class="dashboard-body">
                <div class="placeholder-icon">⚙️</div>
                <h3 class="body-title">Settings Feature Coming Soon</h3>
            </div>
        </div>
    </main>

    <script>
        // 💡 1. HÀM ĐÓNG MỞ SIDEBAR THANH MENU
        function toggleSidebar() {
            const sidebar = document.getElementById('main-sidebar');
            const toggleIcon = document.getElementById('sidebar-toggle-icon');
            if (!sidebar) return;

            sidebar.classList.toggle('collapsed');

            if (sidebar.classList.contains('collapsed')) {
                toggleIcon.className = 'fa-solid fa-angles-right';
            } else {
                toggleIcon.className = 'fa-bars';
            }
        }

        // 💡 2. FETCH SỐ LIỆU THỐNG KÊ DASHBOARD QUÉT TỪ BACKEND
        function fetchDashboardStats() {
            fetch('/api/dashboard-stats')
                .then(response => response.json())
                .then(data => {
                    const totalProjEl = document.getElementById('stat-total-projects');
                    const activeTaskEl = document.getElementById('stat-active-tasks');
                    if (totalProjEl) totalProjEl.innerText = data.totalProjects || 0;
                    if (activeTaskEl) activeTaskEl.innerText = data.activeTasks || 0;
                })
                .catch(err => console.error('Lỗi fetch số liệu cơ học:', err));
        }

        // 💡 3. LIVE DIGITAL CLOCK ENGINE WITH FULL ENGLISH TIMEFORMAT
        function startLiveClock() {
            const timeEl = document.getElementById('live-time');
            const dateEl = document.getElementById('live-date');

            if (!timeEl || !dateEl) return;

            setInterval(() => {
                const now = new Date();
                timeEl.innerText = now.toLocaleTimeString('en-US', { hour12: false });
                const options = { weekday: 'long', year: 'numeric', month: 'short', day: '2-digit' };
                dateEl.innerText = `⏳ ${now.toLocaleDateString('en-US', options)}`;
            }, 1000);
        }

        // Kích hoạt nạp đồng hồ khi mở trang chủ
        document.addEventListener("DOMContentLoaded", () => {
            startLiveClock();
            fetchDashboardStats();
        });

        // 💡 4. ĐIỀU HƯỚNG CHUYỂN TAB SIDEBAR (ĐÃ LOẠI BỎ TOÀN BỘ CÁC HÀM CLASH GÂY LỖI 404)
        document.querySelectorAll('.nav-menu .nav-item').forEach(item => {
            item.addEventListener('click', function (e) {
                e.preventDefault();

                const currentActiveNav = document.querySelector('.nav-menu .nav-item.active');
                if (currentActiveNav) {
                    currentActiveNav.classList.remove('active');
                }
                item.classList.add('active');

                const targetTabId = item.getAttribute('data-tab');

                const currentActiveTab = document.querySelector('.tab-content.active');
                if (currentActiveTab) {
                    currentActiveTab.classList.remove('active');
                }

                const targetTab = document.getElementById(targetTabId);
                if (targetTab) {
                    targetTab.classList.add('active');
                }

                // Chuyển giao toàn quyền nạp dữ liệu cho file /js/tasks.js xử lý
                if (targetTabId === 'dashboard') {
                    fetchDashboardStats();
                } else if (targetTabId === 'tasks') {
                    if (typeof window.loadActiveProjects === 'function') {
                        window.loadActiveProjects();
                    }
                }
            });
        });
        // 🔄 BIẾN TOÀN CỤC LƯU TRỮ ĐỐI TƯỢNG BIỂU ĐỒ ĐỂ TRÁNH LỖI LẶP KHỞI TẠO (CANVAS TRÙNG)
        let lineChartInstance = null;
        let donutChartInstance = null;

        // 📊 FETCH TOÀN BỘ SỐ LIỆU VÀ ĐỔ VÀO BIỂU ĐỒ / MINI CARDS / LỊCH TRÌNH
        function fetchDashboardStats() {
            fetch('/api/dashboard-stats')
                .then(response => response.json())
                .then(data => {
                    // 1. Nạp dữ liệu lên 4 tấm Mini Cards trên đỉnh
                    if (document.getElementById('stat-finance-balance')) document.getElementById('stat-finance-balance').innerText = (data.financeBalance || 0).toLocaleString('vi-VN') + " VND";
                    if (document.getElementById('stat-active-tasks')) document.getElementById('stat-active-tasks').innerText = (data.activeTasks || 0) + " Task";
                    if (document.getElementById('stat-total-projects')) document.getElementById('stat-total-projects').innerText = (data.totalProjects || 0) + " Project";
                    if (document.getElementById('stat-learning-cards')) document.getElementById('stat-learning-cards').innerText = (data.learningCards || 0) + " Thẻ";

                    // 2. 📈 KHỞI TẠO BIỂU ĐỒ SÓNG (HỌC TẬP TRONG TUẦN)
                    const ctxLine = document.getElementById('dashboardLineChart');
                    if (ctxLine) {
                        if (lineChartInstance) lineChartInstance.destroy(); // Xóa biểu đồ cũ phòng bộ nhớ đệm đè
                        lineChartInstance = new Chart(ctxLine, {
                            type: 'line',
                            data: {
                                labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                                datasets: [{
                                    label: 'Giờ học tích lũy',
                                    data: data.learningHoursDataset || [0, 0, 0, 0, 0, 0, 0], // Mảng 7 ngày lấy từ Backend
                                    borderColor: '#2563eb',
                                    backgroundColor: 'rgba(37, 99, 235, 0.1)',
                                    tension: 0.4, // Hiệu ứng sóng uốn lượn êm ái giống ảnh
                                    fill: true
                                }]
                            },
                            options: { responsive: true, maintainAspectRatio: false }
                        });
                    }

                    // 3. 🍩 KHỞI TẠO BIỂU ĐỒ TRÒN (PHÂN BỔ TASK THEO ĐỘ ƯU TIÊN)
                    const ctxDonut = document.getElementById('dashboardDonutChart');
                    if (ctxDonut) {
                        if (donutChartInstance) donutChartInstance.destroy();
                        donutChartInstance = new Chart(ctxDonut, {
                            type: 'doughnut',
                            data: {
                                labels: ['High', 'Medium', 'Low'],
                                datasets: [{
                                    data: data.taskPriorityDataset || [0, 0, 0], // Mảng [High, Medium, Low]
                                    backgroundColor: ['#ef4444', '#f59e0b', '#3b82f6'],
                                    borderWidth: 2
                                }]
                            },
                            options: { responsive: true, maintainAspectRatio: false }
                        });
                    }

                    // 4. 📅 BƠM DỮ LIỆU LỊCH TRÌNH NGÀY HÔM NAY VÀO CỘT PHẢI
                    const scheduleContainer = document.getElementById('dashboard-today-schedule-list');
                    if (scheduleContainer) {
                        scheduleContainer.innerHTML = '';
                        const todaySchedules = data.todaySchedules || [];

                        if (todaySchedules.length === 0) {
                            scheduleContainer.innerHTML = `<p style="font-size: 12px; color: #94a3b8; text-align: center; margin: auto 0;">🎯 Hôm nay thảnh thơi, không có lịch trình nào!</p>`;
                        } else {
                            todaySchedules.forEach(item => {
                                scheduleContainer.insertAdjacentHTML('beforeend', `
                                    <div style="background: #f8fafc; padding: 10px; border-radius: 8px; border-left: 4px solid #2563eb; display: flex; align-items: center; gap: 10px; font-size: 12px;">
                                        <strong style="color: #475569; min-width: 45px;">⏱ ${item.start_time || '00:00'}</strong>
                                        <span style="color: #1e293b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${item.title}</span>
                                    </div>
                                `);
                            });
                        }
                    }
                })
                .catch(err => console.error('Lỗi nạp số liệu thống kê tổng hợp:', err));
        }
    </script>
</body>

</html>