<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ChronosFlow</title>
    <link rel="icon"
        href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>⏳</text></svg>">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="/css/homePageStyles.css">
</head>

<body>

    <aside class="sidebar">
        <div>
            <div class="brand-logo">
                <img src="/images/Dark-Logo.png" alt="ChronosFlow Logo">
            </div>
            <ul class="nav-menu">
                <li class="nav-item active" data-tab="dashboard"><a href="#"><i
                            class="fa-solid fa-house"></i>Dashboard</a></li>
                <li class="nav-item" data-tab="schedules"><a href="#"><i class="fa-solid fa-calendar"></i>Schedules</a>
                </li>
                <li class="nav-item" data-tab="tasks"><a href="#"><i class="fa-solid fa-list-check"></i>Tasks</a></li>
                <li class="nav-item" data-tab="learning"><a href="#"><i class="fa-solid fa-book"></i>Learning</a></li>
                <li class="nav-item" data-tab="settings"><a href="#"><i class="fa-solid fa-gear"></i>Settings</a></li>
            </ul>
        </div>

        <a href="/login" class="btn-logout">
            <span><i class="fa-solid fa-arrow-right-from-bracket"></i>Sign Out</span>
        </a>
    </aside>

    <main class="main-content">

        <div id="dashboard" class="tab-content active">
            <%- include('partials/dashboardSection') %>
        </div>

        <div id="schedules" class="tab-content">
            <%- include('partials/scheduleSection') %>
        </div>

        <div id="tasks" class="tab-content">
            <%- include('partials/tasksSection') %>
        </div>

        <div id="learning" class="tab-content">
            <%- include('partials/learningSection') %>
        </div>

        <div id="settings" class="tab-content">
            <div class="header-content">
                <h1 class="welcome-title">Settings</h1>
            </div>
            <div class="dashboard-body">
                <div class="placeholder-icon">⚙️</div>
                <h3 class="body-title">Settings Feature Coming Soon</h3>
            </div>
        </div>

    </main>

    <script>
        // Hàm gọi ngầm API bốc dữ liệu thống kê từ Backend về cập nhật lên UI
        function fetchDashboardStats() {
            fetch('/api/dashboard-stats')
                .then(response => response.json())
                .then(data => {
                    const totalProjEl = document.getElementById('stat-total-projects');
                    const activeTaskEl = document.getElementById('stat-active-tasks');
                    if (totalProjEl) totalProjEl.innerText = data.totalProjects;
                    if (activeTaskEl) activeTaskEl.innerText = data.activeTasks;
                })
                .catch(err => console.error('Lỗi fetch số liệu cơ học:', err));
        }

        // Kích hoạt chạy lần đầu tiên ngay khi vừa nạp trang chủ
        document.addEventListener("DOMContentLoaded", fetchDashboardStats);

        // Bắt sự kiện chuyển đổi tab menu Sidebar bằng cơ chế an toàn
        document.querySelectorAll('.nav-menu .nav-item').forEach(item => {
            item.addEventListener('click', function (e) {
                e.preventDefault();

                // 1. Gỡ active cũ an toàn (nếu có) và nện active vào nút vừa click
                const currentActiveNav = document.querySelector('.nav-menu .nav-item.active');
                if (currentActiveNav) {
                    currentActiveNav.classList.remove('active');
                }
                item.classList.add('active');

                // 2. Lấy tên nhãn định vị tab
                const targetTabId = item.getAttribute('data-tab');

                // 3. Tìm thằng tab-content nào đang hiện hình để ẩn đi
                const currentActiveTab = document.querySelector('.tab-content.active');
                if (currentActiveTab) {
                    currentActiveTab.classList.remove('active');
                }

                // 4. Bật sáng phân khu nội dung tương ứng
                const targetTab = document.getElementById(targetTabId);
                if (targetTab) {
                    targetTab.classList.add('active');
                }

                // Nếu người dùng lượn quay lại tab dashboard, tự động quét fetch số liệu mới
                if (targetTabId === 'dashboard') {
                    fetchDashboardStats();
                } else if (targetTabId === 'tasks') {
                    loadAllTasks(); // 🔥 Cứ chuyển sang tab tasks là nạp dữ liệu thật lên lập tức!
                }
            });
        });
        // 🔄 HÀM 1: FETCH DANH SÁCH TASK TỪ BACKEND VÀ ĐỔ VÀO CÁC CỘT KANBAN
        function loadAllTasks() {
            console.log("📡 Đang bốc dữ liệu Task thô từ API...");

            fetch('/api/tasks')
                .then(response => response.json())
                .then(tasks => {
                    // 1. Dọn rỗng sạch bách rác cũ trong 3 hộc chứa cột trước khi bơm dữ liệu mới
                    const todoList = document.getElementById('list-todo');
                    const progressList = document.getElementById('list-progress');
                    const doneList = document.getElementById('list-done');

                    if (todoList) todoList.innerHTML = '';
                    if (progressList) progressList.innerHTML = '';
                    if (doneList) doneList.innerHTML = '';

                    // Khởi tạo 3 biến đếm số lượng task cơ học
                    let countTodo = 0, countProgress = 0, countDone = 0;

                    // 2. Chạy vòng lặp quét qua từng cục Task JSON nhận được từ Backend
                    tasks.forEach(task => {
                        // Định dạng lại ngày tháng hiển thị cho đẹp mắt (VD: 29 Jun, 15:00)
                        const dateOption = { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' };
                        const formattedDate = new Date(task.due_date).toLocaleDateString('en-US', dateOption);

                        // Đúc chuỗi HTML Task Item theo đúng cái khuôn CSS cũ của Tuấn
                        // Tìm đoạn đúc chuỗi taskHTML trong hàm loadAllTasks() và đổi thành đoạn này:
                        const taskHTML = `
                            <div class="task-item border-${task.priority.toLowerCase()}">
                            <h4 class="task-item-title">${task.title}</h4>
                            <div class="task-meta">
                                <span class="badge priority-${task.priority.toLowerCase()}">${task.priority}</span>
                                <span class="task-date">⏰ ${formattedDate}</span>
                            </div>
        
                            <div class="task-actions" style="margin-top: 12px; display: flex; justify-content: flex-end;">
                                ${task.status === 'To-Do' ? `<button class="btn-action btn-next" style="background: #2563eb; color: white; border: none; padding: 6px 12px; border-radius: 6px; cursor: pointer;" onclick="updateTaskStatus(${task.id}, 'In Progress')">Start ➔</button>` : ''}
                                ${task.status === 'In Progress' ? `<button class="btn-action btn-next" style="background: #10b981; color: white; border: none; padding: 6px 12px; border-radius: 6px; cursor: pointer;" onclick="updateTaskStatus(${task.id}, 'Done')">Finish ✓</button>` : ''}
                                ${task.status === 'Done' ? `<button class="btn-action" style="background: #ef4444; color: white; border: none; padding: 6px 12px; border-radius: 6px; cursor: pointer;" onclick="deleteTask(${task.id})">🗑️ Xóa</button>` : ''}
                            </div>
                         </div>
                        `;

                        // 3. Phân phối cơ học cái thẻ vừa đúc vào đúng hộc dựa theo 'status' dưới DB
                        if (task.status === 'To-Do') {
                            todoList.innerHTML += taskHTML;
                            countTodo++;
                        } else if (task.status === 'In Progress') {
                            progressList.innerHTML += taskHTML;
                            countProgress++;
                        } else if (task.status === 'Done') {
                            doneList.innerHTML += taskHTML;
                            countDone++;
                        }
                    });

                    // 4. Đập số lượng đếm thực tế lên đầu mỗi cột mặt tiền
                    if (document.getElementById('count-todo')) document.getElementById('count-todo').innerText = countTodo;
                    if (document.getElementById('count-progress')) document.getElementById('count-progress').innerText = countProgress;
                    if (document.getElementById('count-done')) document.getElementById('count-done').innerText = countDone;
                })
                .catch(err => console.error('Lỗi nạp danh sách Task mặt tiền:', err));
        }

        // ➕ HÀM 2: CHẶN SỰ KIỆN SUBMIT FORM VÀ BẮN API TẠO TASK MỚI
        document.addEventListener("DOMContentLoaded", () => {
            // Kích hoạt nạp dữ liệu Task lần đầu nếu người dùng F5 ngay tại tab tasks
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.get('tab') === 'tasks') { loadAllTasks(); }

            const taskForm = document.getElementById('kanban-task-form');
            if (taskForm) {
                taskForm.addEventListener('submit', function (e) {
                    e.preventDefault(); // 🛑 CHẶN ĐỨNG HÀNH VI LOAD LẠI TRANG CỦA TRÌNH DUYỆT!

                    // Bốc dữ liệu từ các ô Input dựa theo ID
                    const title = document.getElementById('task-title').value;
                    const priority = document.getElementById('task-priority').value;
                    const dueDate = document.getElementById('task-duedate').value;

                    // Đóng gói thành cục dữ liệu JSON gửi lên Backend
                    fetch('/api/tasks', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ title, priority, dueDate })
                    })
                        .then(response => {
                            if (!response.ok) throw new Error('Backend từ chối tạo task!');
                            return response.json();
                        })
                        .then(newTask => {
                            console.log("➕ Tạo Task thành công ngầm:", newTask);

                            // Gọi lại hàm loadAllTasks để tự động quét lại DB và vẽ thẻ mới lên giao diện
                            loadAllTasks();

                            // Xóa sạch chữ trong các ô Input cho người dùng nhập lượt tiếp theo
                            taskForm.reset();

                            // 🔥 QUAN TRỌNG: Bật cờ báo dữ liệu Dashboard đã bị đổi (Dirty)
                            isDashboardDirty = true;
                        })
                        .catch(err => alert('Có lỗi cơ học khi thêm Task: ' + err.message));
                });
            }
        });
        // ➔ HÀM 3: BẮN API CẬP NHẬT TRẠNG THÁI MỚI LÊN SERVER
        function updateTaskStatus(taskId, newStatus) {
            console.log(`📡 Đang chuyển Task có ID ${taskId} sang trạng thái mới: ${newStatus}`);

            // Bắn lệnh PUT ngầm kèm ID lên URL và trạng thái mới trong Body
            fetch(`/api/tasks/${taskId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status: newStatus })
            })
                .then(response => {
                    if (!response.ok) throw new Error('Backend từ chối chuyển trạng thái!');
                    return response.json();
                })
                .then(result => {
                    console.log("✓ Đổi trạng thái thành công dứới DB:", result);

                    // 🔥 NÚT THẮT CHÍ MẠNG: Gọi lại động cơ quét lại DB và tự vẽ lại các thẻ sang cột mới!
                    loadAllTasks();
                })
                .catch(err => alert('Lỗi chuyển cột cơ học: ' + err.message));
        }
        // 🗑️ HÀM 4: BẮN API XÓA SỔ TASK VĨNH VIỄN
        function deleteTask(taskId) {
            // Hiện hộp thoại cơ học xác nhận cho chắc ăn, tránh người dùng bấm nhầm
            if (!confirm('Tuấn có chắc chắn muốn xóa vĩnh viễn Task này không?')) {
                return; // Nếu bấm Cancel thì dừng lại, không làm gì cả
            }

            console.log(`📡 Đang ra lệnh xóa vĩnh viễn Task có ID: ${taskId}`);

            // Bắn lệnh DELETE ngầm lên Server kèm ID trên URL
            fetch(`/api/tasks/${taskId}`, {
                method: 'DELETE'
            })
                .then(response => {
                    if (!response.ok) throw new Error('Backend từ chối xóa task!');
                    return response.json();
                })
                .then(result => {
                    console.log("✓ Đã xóa sạch dưới Database:", result);

                    // Gọi lại động cơ nạp dữ liệu để cập nhật lại màn hình và số đếm ngay lập tức
                    loadAllTasks();
                })
                .catch(err => alert('Lỗi xóa task cơ học: ' + err.message));
        }
    </script>
</body>

</html>